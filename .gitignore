###############################################################################
#                         Універсальний .gitignore                            #
#              для навчального архіву (C++, C#, Web, IDEs)                    #
###############################################################################

### --- IDEs & Редактори --- ###

# Visual Studio
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.vsts4000
*.dbmdl

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains (Rider, CLion, IntelliJ)
.idea/
*.sln.iml
*.iws

### --- Build & Артефакти (C#, C++, Java) --- ###

# Спільні папки збірки
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# Тимчасові файли компіляції та бінарники
*.exe
*.dll
*.so
*.dylib
*.app
*.obj
*.o
*.pdb
*.ilk
*.idb
*.recipe
*.tlog
*.log
*.tmp
*.cache
*.bak

### --- Специфічне для мов --- ###

# C++
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.VC.db

# .NET / C#
*.orig
*.pidb
project.lock.json
project.fragment.lock.json

### --- Системні файли та Секрети --- ###

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Налаштування середовища (паролі, ключі)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
