#include <iostream>
#include <iomanip>
#include <cstdlib>
#include <limits>

using namespace std;

void clearConsole() {
#ifdef _WIN32
    // Windows
    system("cls");
#else
    // Linux/macOS
    system("clear"); // Варіант 1
    //cout << "\033[2J\033[1;1H"; // Варіант 2 (швидший)
#endif
}


class Matrix4x4 {
private:
    int data[4][4];

public:
    // 1. Конструктор без параметрів (за замовчуванням 0)
    Matrix4x4() {
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                data[i][j] = 0;
        cout << "[System]: Викликано конструктор за замовчуванням (Matrix 0x0) [ " << this <<  " ]" << endl;
    }

    // 2. Параметризований конструктор (ввід даних)
    Matrix4x4(int val) {
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                data[i][j] = val;
        cout << "[System]: Викликано параметризований конструктор (Matrix filling with " << val << ") [ " << this <<  " ]" << endl;
    }

    // 3. Деструктор
    ~Matrix4x4() {
        cout << "[System]: Об'єкт матриці знищено (Виклик деструктора) [ " << this <<  " ]" << endl;
    }

    // Метод вводу матриці
    void input() {
        cout << "Введіть елементи матриці 4x4:" << endl;
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                cout << "M[" << i << "][" << j << "] = ";
                cin >> data[i][j];
            }
        }
    }

    void inputPro() {
        clearConsole();
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                cout << "=== Заповнення матриці 4x4 ===" << endl;

                // 2. Вимальовуємо матрицю, де поточний елемент - це [ X ]
                for (int r = 0; r < 4; r++) {
                    for (int c = 0; c < 4; c++) {
                        if (r == i && c == j) {
                            cout << setw(5) << "[X]"; // Місце, куди вводимо зараз
                        } else if (r < i || (r == i && c < j)) {
                            cout << setw(5) << data[r][c]; // Вже введені дані
                        } else {
                            cout << setw(5) << "?"; // Ще не заповнені дані
                        }
                    }
                    cout << endl;
                }

                // 3. Сам ввід
                cout << "\nВведіть значення для елемента [" << i << "][" << j << "]: ";

                // Перевірка на ввід числа
                while (!(cin >> data[i][j])) {
                    cin.clear();
                    cin.ignore(numeric_limits<streamsize>::max(), '\n');
                    cout << "[!] Помилка! Введіть ціле число: ";
                }
                clearConsole();
            }
        }
        cout << "\n[OK] Матрицю успішно заповнено!" << endl;
    }


    // Метод виводу матриці
    void display() const {
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                cout << setw(5) << data[i][j] << " ";
            }
            cout << endl;
        }
    }

    // void displayPro() const {
    //     int maxWidth = 0;
    //     int width = 0;
    //     for (int i = 0; i < 4; i++) {
    //         for (int j = 0; j < 4; j++) {
    //             width = to_string(data[i][j]).length();
    //             if (width > maxWidth)
    //                 maxWidth = width;
    //         }
    //     }
    //     maxWidth += 2;
    //     //cout << "maxWidth - " << maxWidth << endl;
    //
    //     for (int i = 0; i < 4; i++) {
    //         for (int j = 0; j < 4; j++) {
    //             cout << setw(maxWidth) << data[i][j] << " ";
    //         }
    //         cout << endl;
    //     }
    // }

    // Пошук максимального елемента
    int findMax() const {
        int maxVal = data[0][0];
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                if (data[i][j] > maxVal) maxVal = data[i][j];
            }
        }
        return maxVal;
    }

    // Перевантаження оператора "+"
    Matrix4x4 operator+(const Matrix4x4& other) {
        Matrix4x4 result;
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                result.data[i][j] = this->data[i][j] + other.data[i][j];
        return result;
    }

    // Перевантаження оператора "-"
    Matrix4x4 operator-(const Matrix4x4& other) {
        Matrix4x4 result;
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                result.data[i][j] = this->data[i][j] - other.data[i][j];
        return result;
    }
};

void runTask() {
    cout << "--- Створення першої матриці ---" << endl;
    Matrix4x4 m1;
    m1.inputPro();
    //m1.input();

    int num = 256;
    cout << "\n--- Створення другої матриці (заповненої '" << num << "' ) ---" << endl;
    Matrix4x4 m2(num);

    cout << "\nМатриця 1:" << endl;
    m1.display();
    cout << "Максимальний елемент M1: " << m1.findMax() << endl;

    cout << "\nМатриця 2:" << endl;

    m2.display();
    cout << "Максимальний елемент M2: " << m2.findMax() << endl;

    cout << "\nРезультат додавання (M1 + M2):" << endl;
    Matrix4x4 resAdd = m1 + m2;
    resAdd.display();

    cout << "\nРезультат віднімання (M1 - M2):" << endl;
    Matrix4x4 resSub = m1 - m2;
    resSub.display();

    cout << endl << endl;
}

int main() {
    runTask();
    return 0;
}